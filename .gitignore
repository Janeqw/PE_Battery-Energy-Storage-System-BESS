# ---- Data ----
# Raw downloads are large, date-stamped, and reproducible — never commit them.
data/raw/
# Processed CSVs ARE committed (they feed the Excel model) — do not ignore them.
!data/processed/

# ---- Excel lock / temp files ----
~$*.xlsx
*.tmp
.~lock.*

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.ipynb_checkpoints/
build/
dist/
.venv/
venv/
env/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.vscode/
.idea/

# ---- Outputs that are regenerated ----
# Keep committed: outputs/dashboard.pdf, outputs/figures/*.png (committed outputs).
# Ignore stray exports:
outputs/*.log
.claude/

# ---- Generated Excel self-check copy (change11) ----
# Excel-first: BESS_Valuation.xlsx is the hand-owned master (committed). Python writes
# this autobuild copy as an independent tie-out check; regenerate with
# `python -m src.build_model`. Not committed.
financial_models/_generated/

# ---- Local-only source/reference materials (not published) ----
reference/
change*.md
icmemo.md

# ---- Source-document verification archive (change10/11) ----
# The raw source documents (AEMO ISP, CSIRO GenCost, RBA daily CSV, and the
# confidential manager deck) live LOCALLY under "data/raw/data source/" — already
# gitignored via `data/raw/` above, so nothing here is committed. Reproduce them
# with that folder's download.sh; the SOURCES_LOG verification trail uses the live
# URLs. The confidential manager deck is never committed.
