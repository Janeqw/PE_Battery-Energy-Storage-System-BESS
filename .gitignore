# ---- Data ----
# Raw downloads are large, date-stamped, and reproducible — never commit them.
data/raw/
# Processed CSVs ARE committed (they feed the Excel model) — do not ignore them.
!data/processed/

# ---- Excel lock / temp files ----
~$*.xlsx
*.tmp
.~lock.*

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.ipynb_checkpoints/
build/
dist/
.venv/
venv/
env/

# ---- OS / editor ----
.DS_Store
Thumbs.db
.vscode/
.idea/

# ---- Outputs that are regenerated ----
# Keep committed: outputs/dashboard.pdf, outputs/figures/*.png (committed outputs).
# Ignore stray exports:
outputs/*.log
.claude/

# ---- Local-only source/reference materials (not published) ----
reference/
change*.md
icmemo.md

# ---- Confidential third-party documents — NEVER commit (change10) ----
# The manager deck / Information Memorandum is the source of the Proposed (manager)
# figures; it is confidential and held offline only.
raw/manager-deck*
raw/*information-memorandum*
raw/*-confidential.*

# ---- Large official PDFs — fetched locally, not committed (change10) ----
# Static, freely-downloadable publications at stable URLs (AEMO ISP ~7.3 MB,
# CSIRO GenCost ~2.2 MB). Keep the repo lean: `bash raw/download.sh` fetches them
# locally and the SOURCES_LOG verification trail links straight to the live docs.
# Only the small, rolling RBA CSV (raw/rba-cgs-10yr-2026-06.csv) is committed.
raw/*.pdf
